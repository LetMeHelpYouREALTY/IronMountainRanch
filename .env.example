# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Canonical site URL — must match Google Search Console property (www recommended)
NEXT_PUBLIC_SITE_URL=https://www.ironmountainranchlasvegas.com

# Public contact email (displayed on site + schema)
# DrDuffy@IronMountainRanchLasVegas.com

# Calendly — in-person consultation (site-wide default)
NEXT_PUBLIC_CALENDLY_CONSULTATION_URL=https://calendly.com/drjanduffy/in-person-real-estate-consultation

# Google Analytics 4 — Iron Mountain Ranch property (public measurement ID)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-7Z86DE17G8

# Google Search Console HTML tag verification (optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token

# Google Business Profile Place ID for Reviews/Directions links (optional)
# Find at: https://developers.google.com/maps/documentation/places/web-service/place-id
# NEXT_PUBLIC_GBP_PLACE_ID=ChIJxxxxxxxx
# NEXT_PUBLIC_GBP_BROWSE_REVIEWS_URL=https://search.google.com/local/reviews?placeid=...
# NEXT_PUBLIC_GBP_REVIEWS_DISABLED=true

# AggregateRating JSON-LD (only after GBP verified + 5+ real reviews)
# NEXT_PUBLIC_GBP_AGGREGATE_RATING_VALUE=4.9
# NEXT_PUBLIC_GBP_AGGREGATE_RATING_COUNT=12

# Site contact (public)
NEXT_PUBLIC_HOST_URL=https://www.ironmountainranchlasvegas.com

# --- Weekly SEO cron (Vercel Production + GitHub Actions) ---
# Vercel Cron → /api/cron/seo-weekly (Mondays 06:00 UTC) dispatches GitHub workflow.
# CRON_SECRET=generate_a_long_random_string
# GITHUB_DISPATCH_TOKEN=fine_grained_pat_with_actions_write_on_this_repo
# GITHUB_REPOSITORY=LetMeHelpYouREALTY/IronMountainRanch

# GitHub Actions secret (Parallel Search API — same key as Parallel MCP)
# PARALLEL_API_KEY=your_parallel_api_key

# Optional tuning for scripts/seo-weekly/run.mjs in CI
# SEO_WEEKLY_LOOP_UNTIL_LIVE=true
# SEO_WEEKLY_MAX_LOOPS=3
# SEO_WEEKLY_GIT_PUSH=true
