# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Canonical site URL — must match Google Search Console property (www recommended)
NEXT_PUBLIC_SITE_URL=https://www.ironmountainranchlasvegas.com

# Public contact email (displayed on site + schema)
# DrDuffy@IronMountainRanchLasVegas.com

# Google Search Console HTML tag verification (optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token

# Google Business Profile Place ID for Reviews/Directions links (optional)
# Find at: https://developers.google.com/maps/documentation/places/web-service/place-id
# NEXT_PUBLIC_GBP_PLACE_ID=ChIJxxxxxxxx

# AggregateRating JSON-LD (only after GBP verified + 5+ real reviews)
# NEXT_PUBLIC_GBP_AGGREGATE_RATING_VALUE=4.9
# NEXT_PUBLIC_GBP_AGGREGATE_RATING_COUNT=12

# Site contact (public)
NEXT_PUBLIC_HOST_URL=https://www.ironmountainranchlasvegas.com
