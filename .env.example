# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Canonical site URL — must match Google Search Console property (www recommended)
NEXT_PUBLIC_SITE_URL=https://www.ironmountainranchlasvegas.com

# --- Google Search Console (see docs/google-search-console-setup.md) ---
# HTML meta tag verification token (content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token

# --- Google Business Profile (see docs/google-business-profile-alignment.md) ---
# NEXT_PUBLIC_GBP_PLACE_ID=ChIJxxxxxxxx
# NEXT_PUBLIC_GBP_WRITEREVIEW_URL=https://g.page/r/xxxxxxxx/review
# NEXT_PUBLIC_GBP_BROWSE_REVIEWS_URL=https://search.google.com/local/reviews?placeid=...
# NEXT_PUBLIC_GBP_REVIEWS_DISABLED=true
# NEXT_PUBLIC_GBP_AGGREGATE_RATING_VALUE=4.9
# NEXT_PUBLIC_GBP_AGGREGATE_RATING_COUNT=12
# Optional: Place-ID-anchored map embed (requires Maps Embed API)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Dr. Jan Duffy headshot — favicon, schema, and about pages (default: /images/agent/dr-jan-duffy.png)
# Cloudflare Images override: https://imagedelivery.net/<account-hash>/<image-id>/public
# NEXT_PUBLIC_DR_JAN_DUFFY_HEADSHOT=
# NEXT_PUBLIC_CLOUDFLARE_IMAGES_ENABLED=true
# NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_HASH=

# Hero backgrounds — Cloudflare R2 (bucket listing-photos, prefix iron-mountain-ranch/heroes)
# Set to false only for offline local dev without R2 access.
# NEXT_PUBLIC_CLOUDFLARE_HERO_MEDIA_ENABLED=true
# NEXT_PUBLIC_R2_MEDIA_BASE_URL=https://pub-55f2185197354e748b122f17b695df69.r2.dev
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...

# Public contact email (displayed on site + schema)
# DrDuffy@IronMountainRanchLasVegas.com

# Calendly — in-person consultation (site-wide default)
NEXT_PUBLIC_CALENDLY_CONSULTATION_URL=https://calendly.com/drjanduffy/in-person-real-estate-consultation

# Google Analytics 4 — Iron Mountain Ranch (hardcoded in lib/analytics.ts as G-7Z86DE17G8)
# Remove any stale NEXT_PUBLIC_GA_MEASUREMENT_ID on Vercel if it points to another property.

# Site contact (public)
NEXT_PUBLIC_HOST_URL=https://www.ironmountainranchlasvegas.com

# --- Weekly SEO cron (Vercel Production + GitHub Actions) ---
# Vercel Cron → /api/cron/seo-weekly (Mondays 06:00 UTC) dispatches GitHub workflow.
# CRON_SECRET=generate_a_long_random_string
# GITHUB_DISPATCH_TOKEN=fine_grained_pat_with_actions_write_on_this_repo
# GITHUB_REPOSITORY=LetMeHelpYouREALTY/IronMountainRanch

# GitHub Actions secret (Parallel Search API — same key as Parallel MCP)
# PARALLEL_API_KEY=your_parallel_api_key

# --- Follow Up Boss (lead ingest) ---
# FUB_API_KEY=your_follow_up_boss_api_key
# FUB_SYSTEM_KEY=optional_system_key_for_higher_rate_limits

# --- Vercel BotID (local dev only) ---
# BOTID_DEV_BYPASS=BAD-BOT
# Set to BAD-BOT to test 403 bot handling locally (ignored in production).

# Optional tuning for scripts/seo-weekly/run.mjs in CI
# SEO_WEEKLY_LOOP_UNTIL_LIVE=true
# SEO_WEEKLY_MAX_LOOPS=3
# SEO_WEEKLY_GIT_PUSH=true
